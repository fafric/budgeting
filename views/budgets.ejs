<%- include('partials/header', { title: 'Budgets' }) %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h4 mb-3">Create budget</h1>
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form method="POST" action="/budgets" class="d-grid gap-3">
          <select name="type" class="form-select" required>
            <option value="monthly">Monthly</option>
            <option value="yearly">Yearly</option>
          </select>
          <input type="text" name="category" class="form-control" placeholder="Category" required>
          <input type="number" step="0.01" min="0.01" name="amount" class="form-control" placeholder="Budget amount" required>
          <input type="number" name="year" class="form-control" value="<%= currentYear %>" required>
          <input type="number" name="month" min="1" max="12" class="form-control" value="<%= currentMonth %>" placeholder="Month number for monthly budget">
          <div class="small text-muted">For yearly budgets, the month value will be ignored.</div>
          <button type="submit" class="btn btn-dark">Save budget</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h4 mb-3">Budget list</h2>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Type</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Year</th>
                <th>Month</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (!items.length) { %>
                <tr><td colspan="6" class="text-muted">No budgets yet.</td></tr>
              <% } %>
              <% items.forEach(item => { %>
                <tr>
                  <td><span class="badge text-bg-secondary"><%= item.type %></span></td>
                  <td><%= item.category %></td>
                  <td><%= formatMoney(item.amount) %></td>
                  <td><%= item.year %></td>
                  <td><%= item.month || '-' %></td>
                  <td>
                    <form method="POST" action="/budgets/<%= item.id %>/delete">
                      <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
