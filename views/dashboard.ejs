<%- include('partials/header', { title: 'Dashboard' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Dashboard</h1>
    <p class="text-muted mb-0">Overview of your money, budgets, goals, and bills.</p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">Total income</div>
        <div class="fs-4 fw-bold"><%= formatMoney(totalIncome) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">Total expenses</div>
        <div class="fs-4 fw-bold text-danger"><%= formatMoney(totalExpenses) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">Net balance</div>
        <div class="fs-4 fw-bold <%= balance >= 0 ? 'text-success' : 'text-danger' %>"><%= formatMoney(balance) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">Saved toward goals</div>
        <div class="fs-4 fw-bold"><%= formatMoney(savings.saved) %></div>
        <div class="small text-muted">Target: <%= formatMoney(savings.target) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">This month income</div>
        <div class="fs-4 fw-bold text-success"><%= formatMoney(monthIncome) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">This month expenses</div>
        <div class="fs-4 fw-bold text-danger"><%= formatMoney(monthExpenses) %></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h2 class="h5 mb-3">Budget status</h2>
        <% if (!budgetOverview.length) { %>
          <p class="text-muted mb-0">No budgets added yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Category</th>
                  <th>Limit</th>
                  <th>Spent</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% budgetOverview.forEach(item => { %>
                  <% const over = Number(item.spent) > Number(item.amount); %>
                  <tr>
                    <td><span class="badge text-bg-secondary"><%= item.type %></span></td>
                    <td><%= item.category %></td>
                    <td><%= formatMoney(item.amount) %></td>
                    <td><%= formatMoney(item.spent) %></td>
                    <td>
                      <% if (over) { %>
                        <span class="badge text-bg-danger">Over</span>
                      <% } else { %>
                        <span class="badge text-bg-success">On track</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h2 class="h5 mb-3">Upcoming bills</h2>
        <% if (!upcomingBills.length) { %>
          <p class="text-muted mb-0">No unpaid bills due in the next 30 days.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Category</th>
                  <th>Amount</th>
                  <th>Due date</th>
                </tr>
              </thead>
              <tbody>
                <% upcomingBills.forEach(bill => { %>
                  <tr>
                    <td><%= bill.name %></td>
                    <td><%= bill.category %></td>
                    <td><%= formatMoney(bill.amount) %></td>
                    <td><%= bill.due_date %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h5 mb-3">Recent transactions</h2>
        <% if (!recentTransactions.length) { %>
          <p class="text-muted mb-0">No transactions yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Label</th>
                  <th>Category</th>
                  <th>Amount</th>
                </tr>
              </thead>
              <tbody>
                <% recentTransactions.forEach(tx => { %>
                  <tr>
                    <td><%= tx.date %></td>
                    <td>
                      <% if (tx.kind === 'Income') { %>
                        <span class="badge text-bg-success">Income</span>
                      <% } else { %>
                        <span class="badge text-bg-danger">Expense</span>
                      <% } %>
                    </td>
                    <td><%= tx.label %></td>
                    <td><%= tx.category %></td>
                    <td class="<%= tx.amount >= 0 ? 'text-success' : 'text-danger' %> fw-semibold"><%= formatMoney(tx.amount) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
