<%- include('partials/header', { title: 'Expenses' }) %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h4 mb-3">Add expense</h1>
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form method="POST" action="/expenses" class="d-grid gap-3">
          <input type="text" name="category" class="form-control" placeholder="Category (Food, Rent, Travel, etc.)" required>
          <input type="text" name="subcategory" class="form-control" placeholder="Subcategory">
          <input type="number" step="0.01" min="0.01" name="amount" class="form-control" placeholder="Amount" required>
          <input type="date" name="date" class="form-control" value="<%= today %>" required>
          <textarea name="note" class="form-control" rows="3" placeholder="Optional note"></textarea>
          <button type="submit" class="btn btn-dark">Save expense</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h4 mb-3">Expense history</h2>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Date</th>
                <th>Category</th>
                <th>Subcategory</th>
                <th>Amount</th>
                <th>Note</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (!items.length) { %>
                <tr><td colspan="6" class="text-muted">No expense records yet.</td></tr>
              <% } %>
              <% items.forEach(item => { %>
                <tr>
                  <td><%= item.date %></td>
                  <td><%= item.category %></td>
                  <td><%= item.subcategory %></td>
                  <td class="text-danger fw-semibold"><%= formatMoney(item.amount) %></td>
                  <td><%= item.note %></td>
                  <td>
                    <form method="POST" action="/expenses/<%= item.id %>/delete">
                      <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
