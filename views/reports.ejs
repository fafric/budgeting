<%- include('partials/header', { title: 'Bills' }) %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h4 mb-3">Add bill</h1>
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form method="POST" action="/bills" class="d-grid gap-3">
          <input type="text" name="name" class="form-control" placeholder="Bill name" required>
          <input type="text" name="category" class="form-control" placeholder="Category" required>
          <input type="number" step="0.01" min="0.01" name="amount" class="form-control" placeholder="Amount" required>
          <input type="date" name="due_date" class="form-control" value="<%= today %>" required>
          <button type="submit" class="btn btn-dark">Save bill</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h4 mb-3">Bills list</h2>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Due date</th>
                <th>Status</th>
                <th></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (!items.length) { %>
                <tr><td colspan="7" class="text-muted">No bills yet.</td></tr>
              <% } %>
              <% items.forEach(item => { %>
                <tr>
                  <td><%= item.name %></td>
                  <td><%= item.category %></td>
                  <td><%= formatMoney(item.amount) %></td>
                  <td><%= item.due_date %></td>
                  <td>
                    <% if (item.status === 'paid') { %>
                      <span class="badge text-bg-success">Paid</span>
                    <% } else { %>
                      <span class="badge text-bg-warning">Unpaid</span>
                    <% } %>
                  </td>
                  <td>
                    <form method="POST" action="/bills/<%= item.id %>/toggle">
                      <button class="btn btn-sm btn-outline-primary"><%= item.status === 'paid' ? 'Mark unpaid' : 'Mark paid' %></button>
                    </form>
                  </td>
                  <td>
                    <form method="POST" action="/bills/<%= item.id %>/delete">
                      <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
