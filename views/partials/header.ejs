<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-body-tertiary">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container d-flex justify-content-between align-items-center gap-3">
      <a class="navbar-brand fw-bold" href="<%= user ? '/dashboard' : '/login' %>">Personal Budget</a>
      <% if (user) { %>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-sm btn-outline-light" href="/dashboard">Dashboard</a>
          <a class="btn btn-sm btn-outline-light" href="/income">Income</a>
          <a class="btn btn-sm btn-outline-light" href="/expenses">Expenses</a>
          <a class="btn btn-sm btn-outline-light" href="/budgets">Budgets</a>
          <a class="btn btn-sm btn-outline-light" href="/goals">Goals</a>
          <a class="btn btn-sm btn-outline-light" href="/bills">Bills</a>
          <a class="btn btn-sm btn-outline-light" href="/reports">Reports</a>
          <a class="btn btn-sm btn-warning" href="/logout">Logout</a>
        </div>
      <% } %>
    </div>
  </nav>
  <div class="container py-4">
